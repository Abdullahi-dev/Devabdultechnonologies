# GEMINI_API_KEY: Required for Gemini AI API calls.

GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://devabdultechnologies.com.ng"

# =========================================================
# EmailJS Configuration (Recommended for Render Static Sites)
# Get these values from https://dashboard.emailjs.com/admin
# Prefix with VITE_ so they are accessible in the browser
# =========================================================
VITE_EMAILJS_SERVICE_ID="your_service_id"
VITE_EMAILJS_TEMPLATE_ID="your_template_id"
VITE_EMAILJS_PUBLIC_KEY="your_public_key"

# =========================================================
# Node.js SMTP Configuration (For Web Service deployments)
# If deployed as a Static Site, these will NOT be used!
# =========================================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_16_character_app_password"
SMTP_RECEIVER="your_receiving_email@gmail.com"

